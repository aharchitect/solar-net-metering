{
    "name": "solar-net-metering",
    "version": "0.1.0",
    "private": true,
    "description": "Node-RED solar net metering flow with extracted function-node sources.",
    "license": "MIT",
    "type": "commonjs",
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "functions:extract": "node scripts/sync-function-nodes.js extract",
        "functions:build": "node scripts/sync-function-nodes.js build",
        "functions:validate": "node scripts/sync-function-nodes.js validate",
        "functions:check": "node scripts/sync-function-nodes.js check",
        "release:prepare": "node scripts/create-release-artifacts.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check .",
        "check": "npm run functions:validate && npm run functions:check && npm run lint && npm run format:check"
    },
    "devDependencies": {
        "@eslint/js": "^9.22.0",
        "eslint": "^9.22.0",
        "eslint-config-prettier": "^10.1.1",
        "globals": "^16.0.0",
        "prettier": "^3.5.3"
    }
}
